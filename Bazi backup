  return String(path).split('.').reduce((o,k)=> (o && o[k] != null) ? o[k] : undefined, obj);
}

function t(key){
  const lang = (typeof state === 'object' && state && state.lang) ? state.lang : 'zh-CN';
  const langDict = (I18N && I18N[lang]) || {};
  const baseDict = (I18N && I18N['zh-CN']) || {};

  // 1) deep path
  let v = deepGet(langDict, key);
  if (v != null) return v;

  // 2) flat dotted key
  if (Object.prototype.hasOwnProperty.call(langDict, key)) return langDict[key];

  // 3) compatibility: drop "report." prefix
  if (key.startsWith('report.')){
    const k2 = key.slice(7);
    v = deepGet(langDict, k2);
    if (v != null) return v;
    if (Object.prototype.hasOwnProperty.call(langDict, k2)) return langDict[k2];
  }

  // 4) fallback to zh-CN with same rules
  v = deepGet(baseDict, key);
  if (v != null) return v;
  if (Object.prototype.hasOwnProperty.call(baseDict, key)) return baseDict[key];

  if (key.startsWith('report.')){
    const k2 = key.slice(7);
    v = deepGet(baseDict, k2);
    if (v != null) return v;
    if (Object.prototype.hasOwnProperty.call(baseDict, k2)) return baseDict[k2];
  }

  return key; // last resort
}

function applyI18n(){
  const lang = (typeof state === 'object' && state && state.lang) ? state.lang : 'zh-CN';
  document.documentElement.lang = lang;

  // text nodes
  document.querySelectorAll('[data-i18n]').forEach(el=>{
    const key = el.getAttribute('data-i18n');
    const val = t(key);
    if (typeof val === 'string' && val !== '') el.textContent = val;
  });

  // option labels
  document.querySelectorAll('option[data-i18n]').forEach(opt=>{
    const key = opt.getAttribute('data-i18n');
    const val = t(key);
    if (typeof val === 'string' && val !== '') opt.textContent = val;
  });

  // placeholder via attribute (generic)
  document.querySelectorAll('[data-i18n-ph]').forEach(el=>{
    const key = el.getAttribute('data-i18n-ph');
    const val = t(key);
    if (typeof val === 'string' && val !== '') el.setAttribute('placeholder', val);
  });

  // explicit placeholders
  const setPh = (id, value) => {
    const el = document.getElementById(id);
    if (el && typeof value === 'string' && value) el.placeholder = value;
  };

  setPh('name', t('form.namePlaceholder'));
  setPh('chatInput', t('chat.placeholder'));

  // Respect privacy: only set auth placeholders when auth UI is actually visible
  const authBox = document.getElementById('authBox');
  const authVisible = authBox
    && !authBox.hasAttribute('hidden')
    && getComputedStyle(authBox).display !== 'none'
    && authBox.dataset.locked !== 'true';

  if (authVisible){
    setPh('email', t('auth.emailPlaceholder'));
    setPh('password', t('auth.passwordPlaceholder'));
  }

  // Re-render report on language change if available
  if (typeof buildProReport === 'function' && window.lastCtx){
    buildProReport(window.lastCtx);
  }
}

