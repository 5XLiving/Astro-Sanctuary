      <div>${t('reportLabels.healthTips')}：${t('report.health.tips.'+stemToPinyin(dayStem))}</div>
      <div>${t('reportLabels.wellnessAdvice')}：${t('report.wellness.default') || '规律作息、适量运动、情绪稳定、少熬夜'}</div>
    </div>

    <div class="butler-section">
      <h4>${t('reportTitles.nearTerm')}</h4>
      <div>${t('reportLabels.overallFortune')}：${nearTermOverall(strongest, weakest)}</div>
      <div>${t('reportLabels.favorableTiming')}：${strongest?`逢${mapName[strongest]}${t('elem.month') || '月'}（${t('report.sameQi') || '同气'}）`:'—'}${weakest?`，或${mapName[weakest]}${t('elem.month') || '月'}（${t('report.complement') || '补缺'}）`:''}${t('report.layout') || '布局'}</div>
      <div>${t('reportLabels.cautions')}：${t('report.cautions.default') || '避开情绪决策，控制支出'}</div>
    </div>

    <div class="butler-section">
      <h4>${t('reportTitles.actions')}</h4>
      <ul class="action-list">
        <li>${t('report.action.weekly') || '每周至少一次'}${weakest?mapName[weakest]:t('elem.fiveElements') || '五行'}${t('report.action.energy') || '元素的"补能"行动（环境、食物、颜色、方向）。'}</li>
        <li>${t('report.action.career') || '职业：依据"'}${career.advice||'—'}${t('report.action.career2') || '"细化下月行动清单（学习/项目/人脉）。'}</li>
        <li>${t('report.action.relationship') || '感情：本周安排一次高质量沟通（30分钟），聚焦彼此需求。'}</li>
        <li>${t('report.action.wealth') || '财富：设立"风险阈值"，偏财机会严格止盈。'}</li>
      </ul>
    </div>
  `;
  const box = $('professionalReport'); if (box) box.innerHTML = html;

  function pctTxt(e){ return Math.round(pcts[e]||0)+'%'; }
  function wealthTrait(ten){
    if(ten.includes('正财')) return t('report.wealth.stable') || '以稳定收入为主，适合积累式理财';
    if(ten.includes('偏财')) return t('report.wealth.opportunity') || '偏财机会多，注意节制风险';
    return t('report.wealth.steady') || '财运平稳，重在技能与口碑带动收入';
  }
  function nearTermOverall(strong,weak){
    if(!strong) return t('report.fortune.steady') || '平稳调整期';
    if(strong===weak) return t('report.fortune.steady') || '平稳调整期';
    if(strong==='木'||strong==='火') return t('report.fortune.upward') || '势头向上，利推广/表达';
    if(strong==='金') return t('report.fortune.focus') || '收敛聚焦，利制度与执行';
    if(strong==='水') return t('report.fortune.study') || '学习调研期，先蓄后发';
    return t('report.fortune.foundation') || '打基础、稳节奏为主';
  }
  function supportElems(dm){
    const map={甲:['水','木'],乙:['水','木'],丙:['木','火'],丁:['木','火'],戊:['火','土'],己:['火','土'],庚:['土','金'],辛:['土','金'],壬:['金','水'],癸:['金','水']};
    const names={木:t('elem.wood'),火:t('elem.fire'),土:t('elem.earth'),金:t('elem.metal'),水:t('elem.water')};
    return (map[dm]||[]).map(x=>names[x]);
  }
  function restrainElems(dm){
    const map={甲:['金'],乙:['金'],丙:['水'],丁:['水'],戊:['木'],己:['木'],庚:['火'],辛:['火'],壬:['土'],癸:['土']};
    const names={木:t('elem.wood'),火:t('elem.fire'),土:t('elem.earth'),金:t('elem.metal'),水:t('elem.water')};
    return (map[dm]||[]).map(x=>names[x]);
  }
  function computeUseful(dm,p){
    const names={木:t('elem.wood'),火:t('elem.fire'),土:t('elem.earth'),金:t('elem.metal'),水:t('elem.water')};
    return Object.entries({木:p.木||0,火:p.火||0,土:p.土||0,金:p.金||0,水:p.水||0})
      .sort((a,b)=>a[1]-b[1]).slice(0,2).map(([k])=>names[k]);
  }
}

  /* =========================
   * MAIN GENERATE
   * ========================= */
  function generate(){
    const birth = ($('birthdate')?.value||'').trim();
    if(!birth) return showErr(t('err.fillBirthdate'));
    if(!/^\d{4}-\d{2}-\d{2}$/.test(birth)) return showErr(t('err.invalidDate'));
    const [Y,M,D]=birth.split('-').map(n=>parseInt(n,10));
    const unknown = $('timeUnknown')?.checked;
    const timeVal = $('birthtime')?.value || '00:00';
    const [hhStr, mmStr] = timeVal.split(':');
    const hh = parseInt((hhStr||'0'),10) || 0;

    setGenLoading(true);
    try{
      const calc = new BaziCalculator();
      const y = calc.yearPillar(Y);
      const m = calc.monthPillar(Y,M,D);
      const d = calc.dayPillar(Y,M,D);
      const h = unknown ? {stem:'-',branch:'-'} : calc.hourPillar(d.stem, hh);

      // Top tiles
      const labels=[y.stem+y.branch, m.stem+m.branch, d.stem+d.branch, unknown? (t('badge.noHour')||'-') : (h.stem+h.branch)];
      renderPillars(labels);

      // Table data (localized element names)
      const stems=[y.stem,m.stem,d.stem, unknown? '-' : h.stem];
      const branch=[y.branch,m.branch,d.branch, unknown? '-' : h.branch];
      const elemMap = {木:t('elem.wood'),火:t('elem.fire'),土:t('elem.earth'),金:t('elem.metal'),水:t('elem.water')};
      const rawElems=[calc.stemElem(y.stem),calc.stemElem(m.stem),calc.stemElem(d.stem), unknown? '-' : calc.stemElem(h.stem)];
      const elements = rawElems.map(e => elemMap[e] || e);
      const nayin=[calc.nayin(y.stem,y.branch),calc.nayin(m.stem,m.branch),calc.nayin(d.stem,d.branch), unknown? '-' : calc.nayin(h.stem,h.branch)];
      renderTable({stem:stems,branch:branch,element:elements,nayin});

      // Element weights (stems + branches)
      const allElems = [calc.stemElem(y.stem),calc.stemElem(m.stem),calc.stemElem(d.stem)]
        .concat(unknown?[]:[calc.stemElem(h.stem)])
        .concat([calc.branchElem(y.branch),calc.branchElem(m.branch),calc.branchElem(d.branch)])
        .concat(unknown?[]:[calc.branchElem(h.branch)]);
      const counts = {木:0,火:0,土:0,金:0,水:0};
      allElems.forEach(e=>{ if(counts[e]!=null) counts[e]++; });
      const total = Object.values(counts).reduce((a,b)=>a+b,0)||1;
      const pcts = Object.fromEntries(Object.entries(counts).map(([k,v])=>[k, 100*v/total]));
      renderBars(pcts);

      // Date summary
      const timeText = unknown ? (t('ui.timeUnknown')||'') : (t('ui.hourSuffix')||'{hh}:{mm}')
        .replace('{hh}', String(hh).padStart(2,'0'))
        .replace('{mm}', String(parseInt(mmStr||'0',10)||0).padStart(2,'0'));
      const btxt = (t('ui.birthSummary')||'')
        .replace('{y}',Y)
        .replace('{m}',M)
        .replace('{d}',D)
        .replace('{timeText}', timeText);
      const bd=$('bazi-date'); if (bd) bd.textContent = btxt;

      // Ten Gods & report
      const tg = calc.tenGods(d.stem, stems);
      const ctx = { pcts, dayStem: d.stem, tenGods: tg, unknown };
      buildProReport(ctx);

      showResult();
    }catch(e){
      console.error(e);
      showErr(t('err.generateFail'));
    }finally{
      setGenLoading(false);
    }
  }

  /* =========================
   * CHAT FLOAT (local echo)
   * ========================= */
  function appendMsg(text, who='user'){
    const box=$('chatMessages'); if(!box) return;
    const div=document.createElement('div');
    div.className = who==='user' ? 'me-msg' : 'ss-msg';
    div.textContent = text;
    box.appendChild(div);
    box.scrollTop = box.scrollHeight;
  }

  /* =========================
   * AUTH FIELDS: HIDE BY DEFAULT (reveal on demand)
   * ========================= */
  function setupAuthReveal(){
    const fields = $('authFields');
    if(!fields) return;
    fields.style.display='none';
    const btn = document.createElement('button');
    btn.type='button';
    btn.className='btn ghost block';
    btn.id='revealAuthBtn';
    btn.textContent = '👁 显示账号输入 / Reveal login fields';
    // insert before login form
    const panelBody = fields.parentElement;
    panelBody.insertBefore(btn, panelBody.firstChild);
    btn.addEventListener('click', ()=>{
      const visible = fields.style.display!=='none';
      fields.style.display = visible ? 'none' : 'grid';
      btn.textContent = visible ? '👁 显示账号输入 / Reveal login fields' : '🙈 隐藏账号输入 / Hide login fields';
    });

    // prevent real submit (no echo of credentials)
    const loginForm = $('loginForm');
    const registerForm = $('registerForm');
    const resetBtn = $('resetBtn');
    const err = $('authError');
    function block(e){
      e?.preventDefault();
      if(err){ err.style.display='block'; err.textContent='Auth not wired yet / 登录暂未接入'; setTimeout(()=>err.style.display='none',3000); }
    }
    if(loginForm) loginForm.addEventListener('submit', block);
    if(registerForm) registerForm.addEventListener('submit', block);
    if(resetBtn) resetBtn.addEventListener('click', block);
  }

/* =========================
 * BOOTSTRAP EVENTS
 * ========================= */
function onLangChange(e){
  state.lang = (e.target?.value) || 'zh-CN';
  try { localStorage.setItem('5x_lang', state.lang); } catch {}
  applyI18n();
}

function boot(){
  // guard: prevent double init if this script is injected twice
  if (boot._didBoot) return;
  boot._didBoot = true;

  // language select
  const langSel = $('langSelect');
  if (langSel) {
    langSel.value = state.lang;
    langSel.addEventListener('change', onLangChange, { once:false });
  }
  applyI18n();

  // time unknown toggle
  const unk = $('timeUnknown'), bt = $('birthtime');
  if (unk && bt){
    const sync = ()=>{
      bt.disabled = !!unk.checked;
      bt.style.opacity = bt.disabled ? 0.5 : 1;
    };
    unk.addEventListener('change', sync);
    sync();
  }

  // generate button
  $('genBtn')?.addEventListener('click', generate);

  // chat float
  const chatToggle = $('chatToggle');
  const chatFloat  = $('chatFloat');
  const chatClose  = $('chatClose');
  const chatSend   = $('chatSend');
  const chatInput  = $('chatInput');

  if (chatToggle && chatFloat){
    chatToggle.addEventListener('click', ()=>{
      const cur = getComputedStyle(chatFloat).display;
      chatFloat.style.display = (cur === 'none' ? 'flex' : 'none');
    });
  }
  if (chatClose && chatFloat){
    chatClose.addEventListener('click', ()=>{ chatFloat.style.display = 'none'; });
  }
  if (chatSend && chatInput){
    const send = ()=>{
      const q = (chatInput.value || '').trim();
      if (!q) return;
      appendMsg(q, 'user');
      chatInput.value = '';
      const tpl = t('chatDyn.autoReply') || '收到：{q}。';
      appendMsg(tpl.replace('{q}', q), 'bot');
    };
    chatSend.addEventListener('click', send);
    chatInput.addEventListener('keydown', (e)=>{
      if (e.key === 'Enter'){ e.preventDefault(); send(); }
    });
  }

  // header clock (run once)
  if (typeof tickNow === 'function') {
    tickNow();
    if (!boot._clock) boot._clock = setInterval(tickNow, 1000);
  }

  // hide auth inputs by default; reveal only via your handler
  if (typeof setupAuthReveal === 'function') {
    setupAuthReveal();
  }
}

// run once when DOM is ready
if (document.readyState === 'loading') {
  document.addEventListener('DOMContentLoaded', boot, { once:true });
} else {
  boot();
}
})();
</script>
<script>
/* === LANG SWITCH PATCH === */
(function initLangSwitch(){
  const $ = (id)=>document.getElementById(id);

  // Use saved lang or default to zh-CN
  const supported = Object.keys(window.I18N || {});
  const saved = localStorage.getItem('5x_lang');
  let lang = supported.includes(saved) ? saved : 'zh-CN';

  // Allow ?lang=en (optional)
  try{
    const q = new URLSearchParams(location.search).get('lang');
    if (q && supported.includes(q)) lang = q;
  }catch{}

  // Persist + reflect
  window.state = Object.assign({ lang }, (window.state||{}));
  if (typeof applyI18n === 'function') applyI18n();

  // Sync <select> value
  const sel = $('langSelect');
  if (sel) {
    sel.value = window.state.lang;
    sel.addEventListener('change', (e)=>{
      window.state.lang = e.target.value;
      localStorage.setItem('5x_lang', window.state.lang);
      if (typeof applyI18n === 'function') applyI18n();
    });
  }

  // Optional: show clock if you have #nowBox
  if (typeof tickNow === 'function') {
    tickNow(); setInterval(tickNow, 60_000);
  }
})();
</script>
<script>
/* === NOW + BIRTH DEFAULTS (SGT) === */
(function () {
  const $ = (id) => document.getElementById(id);
  const TZ = 'Asia/Singapore';
  const localeMap = { 'zh-CN':'zh-CN','zh-TW':'zh-TW','en':'en-US','ja':'ja-JP','th':'th-TH','ms':'ms' };
  const getLocale = () => (localeMap[(window.state && window.state.lang) || 'zh-CN'] || 'en-US');

  // Live clock in header
  window.tickNow = function () {
    const box = $('nowBox'); if (!box) return;
    const fmt = new Intl.DateTimeFormat(getLocale(), {
      weekday:'short', year:'numeric', month:'2-digit', day:'2-digit',
      hour:'2-digit', minute:'2-digit', hour12:false, timeZone: TZ
    });
    box.textContent = fmt.format(new Date()) + ' (SGT)';
  };

  // One-time fill for birthdate/time (only if empty)
  function initBirthDefaults() {
    const bd = $('birthdate') || document.querySelector('[name="birthdate"]');
    const bt = $('birthtime') || document.querySelector('[name="birthtime"]');
    const unk = $('timeUnknown') || $('unknown') || document.querySelector('#birthtimeUnknown, [name="timeUnknown"]');

    const nowSG = new Date(new Date().toLocaleString('en-US', { timeZone: TZ }));

    if (bd && !bd.value) {
      const y = nowSG.getFullYear();
      const m = String(nowSG.getMonth() + 1).padStart(2, '0');
      const d = String(nowSG.getDate()).padStart(2, '0');
      bd.value = `${y}-${m}-${d}`;            // works for <input type="date">
    }

    if (bt) {
      const hh = String(nowSG.getHours()).padStart(2, '0');
      const mm = String(nowSG.getMinutes()).padStart(2, '0');
      if (!bt.value) bt.value = `${hh}:${mm}`; // works for <input type="time">

      const setUnknownState = () => {
        const isUnknown = !!(unk && unk.checked);
        bt.disabled = isUnknown;
        if (isUnknown) bt.value = '';
      };
      setUnknownState();

      if (unk && !unk._wired) {
        unk._wired = true;
        unk.addEventListener('change', () => {
          if (unk.checked) {
            bt.disabled = true; bt.value = '';
          } else {
            bt.disabled = false;
            if (!bt.value) {
              const n = new Date(new Date().toLocaleString('en-US', { timeZone: TZ }));
              bt.value = `${String(n.getHours()).padStart(2,'0')}:${String(n.getMinutes()).padStart(2,'0')}`;
            }
          }
        });
      }
    }
  }

  // Run now
  initBirthDefaults();
  tickNow(); setInterval(tickNow, 60_000);

  // When language changes, keep the clock format in sync (don’t touch inputs)
  const _applyI18n = window.applyI18n;
  window.applyI18n = function () {
    if (typeof _applyI18n === 'function') _applyI18n();
    tickNow();
  };
})();
</script>  
